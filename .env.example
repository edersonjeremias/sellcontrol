# Copie este arquivo para .env e preencha com suas credenciais
# Supabase: Project Settings > API

VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Após rodar o schema.sql, execute no SQL Editor do Supabase:
# INSERT INTO tenants (nome) VALUES ('Sua Empresa') RETURNING id;
# Cole o UUID retornado abaixo:
VITE_TENANT_ID=seu_tenant_uuid_aqui
